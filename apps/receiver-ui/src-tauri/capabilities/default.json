{
  "identifier": "default",
  "description": "Default capabilities for the receiver Tauri shell",
  "windows": ["*"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/receiver",
          "sidecar": true
        }
      ]
    },
    "shell:allow-kill",
    "updater:default"
  ]
}
